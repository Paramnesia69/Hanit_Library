{
  "name": "hanit-library",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync:evrit": "node scripts/sync-evrit-library.mjs",
    "pull:db": "node --env-file=.env.development.local scripts/sync-from-upstash.mjs",
    "pull:db:dry": "node --env-file=.env.development.local scripts/sync-from-upstash.mjs --dry",
    "push:db": "node --env-file=.env.development.local scripts/push-enrichment-to-upstash.mjs",
    "push:db:dry": "node --env-file=.env.development.local scripts/push-enrichment-to-upstash.mjs --dry",
    "enrich:new": "node --env-file=.env.development.local scripts/enrich-new-books.mjs",
    "enrich:new:dry": "node --env-file=.env.development.local scripts/enrich-new-books.mjs --dry"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "@upstash/redis": "^1.38.0",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.17",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright-core": "^1.61.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
